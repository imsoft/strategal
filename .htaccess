# =============================================================================
# SOLO si el DocumentRoot apunta a la RAIZ del proyecto (artisan, app/, public/).
# NO copies este archivo a public_html: usa alli solo public/.htaccess (mismo que public_html/.htaccess del repo).
#
# AH00124 (10 internal redirects): suele ser bucle al reescribir a public/ sin [END].
# [END] detiene TODO el motor de reescritura para esta peticion (Apache 2.3.9+).
# =============================================================================

DirectoryIndex public/index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Ya bajo /public/: no reescribir de nuevo (evita public/public/... en algunos entornos)
    RewriteCond %{REQUEST_URI} ^/public/ [NC]
    RewriteRule ^ - [L]

    # Una sola pasada efectiva hacia public/; [END] evita bucle AH00124
    RewriteRule ^(.*)$ public/$1 [END]
</IfModule>
