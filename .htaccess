# =============================================================================
# SOLO cuando el DocumentRoot del dominio apunta a la RAIZ de este proyecto
# (donde estan artisan, app/, vendor/, carpeta public/, etc.).
# =============================================================================
#
# NUNCA copies este archivo a public_html ni a public/.
# En public_html debe ir SOLO el mismo contenido que public/.htaccess
# (sin reglas que manden a la subcarpeta "public/").
#
# Si tu hosting usa public_html como raiz del sitio, sube el archivo:
#   public_html/.htaccess   (esta en el repo, copia su contenido al servidor)
# y BORRA de public_html cualquier .htaccess que reescriba a "public/".
# =============================================================================

DirectoryIndex public/index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
